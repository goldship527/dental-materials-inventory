# Local development only. Do not put real production secrets in this file.
DATABASE_URL="postgresql://dental_inventory:local_dev_only_password@localhost:5432/dental_materials_inventory?schema=public"
AUTH_SECRET="replace-with-a-local-random-secret"
AUTH_URL="http://localhost:3000"

# Optional seed settings. Use non-secret local defaults only.
DEMO_LOGIN_EMAIL="test@example.com"
DEMO_LOGIN_PASSWORD="password"
DEMO_USER_NAME="自分"

# Optional product photo storage. Leave unset to use local fallback storage.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=

# Optional daily digest notifications. Keep disabled in local development.
NOTIFICATIONS_ENABLED=false
RESEND_API_KEY=
NOTIFICATION_EMAIL_FROM=
CRON_SECRET=
APP_BASE_URL="http://localhost:3000"
