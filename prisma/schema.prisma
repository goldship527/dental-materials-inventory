generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinics                 Clinic[]
  users                   User[]
  staffOperators          StaffOperator[]
  products                Product[]
  productSuppliers        ProductSupplier[]
  suppliers               Supplier[]
  productBarcodes         ProductBarcode[]
  productImportHistories  ProductImportHistory[]
  auditLogs               AuditLog[]
  setting                 OrganizationSetting?
  notificationPreferences NotificationPreference[]
  notificationDeliveries  NotificationDelivery[]
}

model OrganizationSetting {
  id                  String   @id @default(cuid())
  organizationId      String   @unique
  anomalyOutThreshold Float    @default(3.0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

model Clinic {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  address        String?
  phone          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization             Organization                    @relation(fields: [organizationId], references: [id])
  stockItems               StockItem[]
  stockLots                StockLot[]
  stockMovements           StockMovement[]
  barcodeScanLogs          BarcodeScanLog[]
  favoriteCards            FavoriteProductCard[]
  orderRecords             OrderRecord[]
  orderRequests            OrderRequest[]
  stocktakeSessions        StocktakeSession[]
  staffOperatorAssignments StaffOperatorClinicAssignment[]
  userClinicAssignments    UserClinicAssignment[]
  productImportHistories   ProductImportHistory[]

  @@index([organizationId])
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String   @unique
  passwordHash   String
  role           String   @default("STAFF")
  isActive       Boolean  @default(true)
  pinCodeHash    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization               Organization             @relation(fields: [organizationId], references: [id])
  clinicAssignments          UserClinicAssignment[]
  stockMovements             StockMovement[]
  orderRecords               OrderRecord[]            @relation("OrderRecordCreatedBy")
  orderRequests              OrderRequest[]           @relation("OrderRequestCreatedBy")
  receivedOrderRequests      OrderRequest[]           @relation("OrderRequestReceivedBy")
  barcodeScanLogs            BarcodeScanLog[]
  stocktakeSessionsStarted   StocktakeSession[]       @relation("StocktakeSessionStartedBy")
  stocktakeSessionsCommitted StocktakeSession[]       @relation("StocktakeSessionCommittedBy")
  stocktakeItemsCounted      StocktakeSessionItem[]   @relation("StocktakeSessionItemCountedBy")
  productImportHistories     ProductImportHistory[]
  auditLogs                  AuditLog[]
  notificationPreferences    NotificationPreference[]
  notificationDeliveries     NotificationDelivery[]

  @@index([organizationId])
}

model NotificationPreference {
  id                  String   @id @default(cuid())
  organizationId      String
  userId              String
  channel             String   @default("EMAIL")
  isEnabled           Boolean  @default(true)
  dailyDigestTime     String   @default("07:00")
  dailyDigestWeekdays String   @default("MON,TUE,WED,THU,FRI")
  itemsJson           Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([userId, channel])
  @@index([organizationId])
}

model NotificationDelivery {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  channel        String
  status         String
  subject        String
  bodyDigestJson Json
  attemptCount   Int       @default(0)
  lastError      String?
  scheduledFor   DateTime
  sentAt         DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId, scheduledFor])
  @@index([userId])
  @@index([status])
}

model UserClinicAssignment {
  id       String @id @default(cuid())
  userId   String
  clinicId String

  user   User   @relation(fields: [userId], references: [id])
  clinic Clinic @relation(fields: [clinicId], references: [id])

  @@unique([userId, clinicId])
  @@index([clinicId])
}

model StaffOperator {
  id             String   @id @default(cuid())
  organizationId String
  displayName    String
  barcode        String
  operatorType   String   @default("REGULAR")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization          Organization                    @relation(fields: [organizationId], references: [id])
  clinicAssignments     StaffOperatorClinicAssignment[]
  stockMovements        StockMovement[]
  orderedOrderRecords   OrderRecord[]                   @relation("OrderRecordOrderedByStaff")
  receivedOrderRequests OrderRequest[]                  @relation("OrderRequestReceivedByStaff")

  @@unique([organizationId, barcode])
  @@index([organizationId, isActive])
  @@index([barcode])
}

model StaffOperatorClinicAssignment {
  id              String @id @default(cuid())
  staffOperatorId String
  clinicId        String

  staffOperator StaffOperator @relation(fields: [staffOperatorId], references: [id])
  clinic        Clinic        @relation(fields: [clinicId], references: [id])

  @@unique([staffOperatorId, clinicId])
  @@index([clinicId])
}

model LoginAttempt {
  id           String    @id @default(cuid())
  email        String
  ipAddress    String
  failedCount  Int       @default(0)
  lockedUntil  DateTime?
  lastFailedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([email, ipAddress])
  @@index([lockedUntil])
  @@index([updatedAt])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorUserId    String?
  action         String
  targetType     String
  targetId       String?
  detailsJson    Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  actorUser    User?        @relation(fields: [actorUserId], references: [id])

  @@index([organizationId, createdAt])
  @@index([actorUserId])
  @@index([action])
  @@index([targetType, targetId])
}

model Supplier {
  id                 String   @id @default(cuid())
  organizationId     String
  name               String
  address            String?
  phone              String?
  fax                String?
  email              String?
  contactPersonName  String?
  contactPersonEmail String?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  products         Product[]
  productSuppliers ProductSupplier[]
  orderRecords     OrderRecord[]
  orderRequests    OrderRequest[]

  @@index([organizationId])
}

model Product {
  id                  String    @id @default(cuid())
  organizationId      String
  productCode         String?
  janCode             String?
  internalCode        String?
  name                String
  nameKana            String?
  category            String?
  manufacturer        String?
  specification       String?
  orderUnit           String?
  primarySupplierId   String?
  supplierProductCode String?
  standardPrice       Float?
  defaultMinStock     Int       @default(0)
  stockUsageMode      String    @default("NONE")
  isActive            Boolean   @default(true)
  importSource        String?
  notes               String?
  photoFileName       String?
  photoMimeType       String?
  photoUpdatedAt      DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization     Organization           @relation(fields: [organizationId], references: [id])
  primarySupplier  Supplier?              @relation(fields: [primarySupplierId], references: [id])
  stockItems       StockItem[]
  stockLots        StockLot[]
  stockMovements   StockMovement[]
  productSuppliers ProductSupplier[]
  favoriteCards    FavoriteProductCard[]
  orderRequests    OrderRequest[]
  barcodes         ProductBarcode[]
  barcodeScanLogs  BarcodeScanLog[]
  stocktakeItems   StocktakeSessionItem[]

  @@unique([organizationId, janCode])
  @@index([organizationId])
  @@index([primarySupplierId])
  @@index([name])
  @@index([janCode])
  @@index([productCode])
  @@index([internalCode])
  @@index([organizationId, importSource])
}

model ProductImportHistory {
  id             String   @id @default(cuid())
  organizationId String
  clinicId       String?
  userId         String
  sourceType     String
  fileName       String?
  dealerNames    String?
  totalRows      Int
  validRows      Int
  createdRows    Int
  skippedRows    Int
  errorRows      Int
  warningRows    Int
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  clinic       Clinic?      @relation(fields: [clinicId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([clinicId])
  @@index([userId])
}

model ProductSupplier {
  id                  String   @id @default(cuid())
  organizationId      String
  productId           String
  supplierId          String
  supplierProductCode String?
  orderUnit           String?
  standardPrice       Float?
  isPrimary           Boolean  @default(false)
  isActive            Boolean  @default(true)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
  supplier     Supplier     @relation(fields: [supplierId], references: [id])

  @@unique([productId, supplierId])
  @@index([organizationId])
  @@index([supplierId])
  @@index([productId, isPrimary])
}

model ProductBarcode {
  id             String   @id @default(cuid())
  organizationId String
  productId      String
  barcode        String
  barcodeType    String   @default("JAN")
  unitLabel      String?
  isPrimary      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])

  @@unique([productId, barcode])
  @@unique([organizationId, barcode])
  @@index([organizationId])
  @@index([barcode])
  @@index([productId])
}

model StockItem {
  id                String   @id @default(cuid())
  clinicId          String
  productId         String
  quantity          Int      @default(0)
  inUseQuantity     Int      @default(0)
  discardedQuantity Int      @default(0)
  minStock          Int?
  location          String?
  isUsed            Boolean  @default(true)
  updatedAt         DateTime @updatedAt

  clinic  Clinic  @relation(fields: [clinicId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([clinicId, productId])
  @@index([productId])
}

model StockLot {
  id             String    @id @default(cuid())
  clinicId       String
  productId      String
  lotNumber      String    @default("")
  expiryDateText String    @default("")
  expiryDate     DateTime?
  quantity       Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  clinic  Clinic  @relation(fields: [clinicId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([clinicId, productId, lotNumber, expiryDateText])
  @@index([clinicId, productId])
  @@index([clinicId, expiryDate])
}

model StockMovement {
  id                 String    @id @default(cuid())
  clinicId           String
  productId          String
  movementType       String
  quantity           Int
  beforeQuantity     Int
  afterQuantity      Int
  reason             String?
  sourceType         String?
  sourceId           String?
  revertOfId         String?
  revertedAt         DateTime?
  revertedById       String?
  lotNumber          String?
  expiryDateText     String?
  expiryDate         DateTime?
  userId             String
  performedByStaffId String?
  memo               String?
  createdAt          DateTime  @default(now())

  clinic           Clinic         @relation(fields: [clinicId], references: [id])
  product          Product        @relation(fields: [productId], references: [id])
  user             User           @relation(fields: [userId], references: [id])
  performedByStaff StaffOperator? @relation(fields: [performedByStaffId], references: [id])

  @@index([clinicId, createdAt])
  @@index([productId])
  @@index([userId])
  @@index([performedByStaffId])
  @@index([revertOfId])
}

model StocktakeSession {
  id                String    @id @default(cuid())
  clinicId          String
  status            String    @default("IN_PROGRESS")
  memo              String?
  startedAt         DateTime  @default(now())
  committedAt       DateTime?
  discardedAt       DateTime?
  startedByUserId   String
  committedByUserId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  clinic          Clinic                 @relation(fields: [clinicId], references: [id])
  startedByUser   User                   @relation("StocktakeSessionStartedBy", fields: [startedByUserId], references: [id])
  committedByUser User?                  @relation("StocktakeSessionCommittedBy", fields: [committedByUserId], references: [id])
  items           StocktakeSessionItem[]

  @@index([clinicId, status, startedAt])
}

model StocktakeSessionItem {
  id               String    @id @default(cuid())
  sessionId        String
  productId        String
  expectedQuantity Int
  countedQuantity  Int?
  diff             Int?
  status           String    @default("PENDING")
  memo             String?
  countedAt        DateTime?
  countedByUserId  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  session       StocktakeSession @relation(fields: [sessionId], references: [id])
  product       Product          @relation(fields: [productId], references: [id])
  countedByUser User?            @relation("StocktakeSessionItemCountedBy", fields: [countedByUserId], references: [id])

  @@unique([sessionId, productId])
  @@index([sessionId, status])
  @@index([productId])
}

model BarcodeScanLog {
  id                 String    @id @default(cuid())
  clinicId           String
  userId             String
  productId          String?
  rawInput           String    @db.Text
  extractedBarcode   String?
  extractedJan13     String?
  extractedGtin      String?
  scannedAtText      String?
  scannedAt          DateTime?
  lotNumber          String?
  serialNumber       String?
  expiryDateText     String?
  expiryDate         DateTime?
  matchType          String    @default("NO_MATCH")
  sampleJanCode      String?
  sampleProductName  String?
  sampleManufacturer String?
  sampleSourceFile   String?
  sampleSourceSheet  String?
  sampleSourceRow    Int?
  sampleJmdnCode     String?
  sampleGenericName  String?
  resolveStatus      String    @default("UNRESOLVED")
  resolvedAt         DateTime?
  resolvedByUserId   String?
  resolvedNote       String?
  createdAt          DateTime  @default(now())

  clinic  Clinic   @relation(fields: [clinicId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@index([clinicId, createdAt])
  @@index([clinicId, resolveStatus, createdAt])
  @@index([userId])
  @@index([productId])
  @@index([extractedBarcode])
  @@index([matchType])
}

model FavoriteProductCard {
  id           String  @id @default(cuid())
  clinicId     String
  productId    String
  displayOrder Int     @default(0)
  categoryTab  String?

  clinic  Clinic  @relation(fields: [clinicId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([clinicId, productId])
  @@index([productId])
  @@index([clinicId, displayOrder])
}

enum OrderRequestStatus {
  DRAFT
  CONFIRMED
  SKIPPED
  ORDERED
}

enum OrderSendMethod {
  FAX
  EMAIL
  PHONE
  LINE
}

model OrderRequest {
  id                     String             @id @default(cuid())
  clinicId               String
  productId              String
  supplierId             String?
  orderRecordId          String?
  status                 OrderRequestStatus @default(DRAFT)
  requestedQuantity      Int
  memo                   String?
  orderedAt              DateTime?
  orderedMethod          OrderSendMethod?
  orderedMemo            String?
  supplierResponseMemo   String?
  receivedQuantity       Int?
  receivedAt             DateTime?
  receivedMemo           String?
  receivedLotNumber      String?
  receivedExpiryDateText String?
  receivedExpiryDate     DateTime?
  receivedByUserId       String?
  receivedByStaffId      String?
  createdByUserId        String
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  clinic          Clinic         @relation(fields: [clinicId], references: [id])
  product         Product        @relation(fields: [productId], references: [id])
  supplier        Supplier?      @relation(fields: [supplierId], references: [id])
  orderRecord     OrderRecord?   @relation(fields: [orderRecordId], references: [id])
  createdByUser   User           @relation("OrderRequestCreatedBy", fields: [createdByUserId], references: [id])
  receivedByUser  User?          @relation("OrderRequestReceivedBy", fields: [receivedByUserId], references: [id])
  receivedByStaff StaffOperator? @relation("OrderRequestReceivedByStaff", fields: [receivedByStaffId], references: [id])

  @@index([clinicId, status])
  @@index([productId])
  @@index([supplierId])
  @@index([orderRecordId])
  @@index([createdByUserId])
  @@index([receivedByUserId])
  @@index([receivedByStaffId])
}

model OrderRecord {
  id                   String          @id @default(cuid())
  clinicId             String
  supplierId           String?
  orderedAt            DateTime
  orderedMethod        OrderSendMethod
  orderedMemo          String?
  supplierResponseMemo String?
  createdByUserId      String
  orderedByStaffId     String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  clinic         Clinic         @relation(fields: [clinicId], references: [id])
  supplier       Supplier?      @relation(fields: [supplierId], references: [id])
  createdByUser  User           @relation("OrderRecordCreatedBy", fields: [createdByUserId], references: [id])
  orderedByStaff StaffOperator? @relation("OrderRecordOrderedByStaff", fields: [orderedByStaffId], references: [id])
  orderRequests  OrderRequest[]

  @@index([clinicId, orderedAt])
  @@index([supplierId])
  @@index([createdByUserId])
  @@index([orderedByStaffId])
}
